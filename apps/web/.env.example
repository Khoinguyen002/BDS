PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Chống spam bằng Cloudflare Turnstile (Cần lấy từ dashboard của CF)
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Gửi email bằng Resend (Cần lấy API Key từ resend.com)
# RESEND_API_KEY=re_your_api_key_here

# Redis fallback cho Lead (Lấy từ console.upstash.com)
# UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Token bí mật để đồng bộ xoá Cache giữa CMS và Web (Bắt buộc phải khớp nhau 2 bên)
REVALIDATE_SECRET=bds-super-secret-token-2026
